    {
      "featureName": "network_instrumentation",
      "sessionSampleRate": 0,
      "sdks": [],
      "config": null
    }
  ],
  "batchConfig": {
    "batchLogs": {
      "maxExportBatchSize": 1,
      "scheduleDelay": 1000
    },
    "batchSpans": {
      "maxExportBatchSize": 1,
      "scheduleDelay": 1000
    }
  }
